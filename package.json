{
  "name": "azdo-mcp",
  "version": "0.1.0",
  "author": "DmitryB",
  "private": true,
  "description": "Personal MCP server that makes Azure DevOps operable from within Claude Code. A minimal set of primitives plus a library of Claude Skills — the first MCP+Skills stack for Azure DevOps.",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node --env-file=.env --import tsx src/index.ts",
    "inspect": "mcp-inspector node --env-file=.env --import tsx src/index.ts",
    "type-check": "tsc --noEmit",
    "install:bmad": "npx bmad-method@6.3.0 install"
  },
  "dependencies": {
    "@azure-devops/mcp": "2.6.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "azure-devops-node-api": "^15.1.2",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.21.2",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.0"
}
